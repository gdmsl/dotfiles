#!/usr/bin/env bash

# Load local overrides
[ -f "$HOME/.bashrc.local" ] && source "$HOME/.bashrc.local"

# Don't run if not interactive
[[ $- != *i* ]] && return

# Vi mode
set -o vi

# History
HISTCONTROL=ignoreboth:erasedups
HISTSIZE=50000
HISTFILESIZE=50000
shopt -s histappend
PROMPT_COMMAND="history -a; ${PROMPT_COMMAND:-}"

# Shell options
shopt -s checkwinsize
shopt -s globstar 2>/dev/null

# ── Aliases (mirroring fish) ─────────────────────────────────────────

# Files & directories
alias mv='mv -iv'
alias cp='cp -riv'
alias mkdir='mkdir -vp'
if command -v eza &>/dev/null; then
	alias ls='eza --color=always --icons --group-directories-first'
	alias la='eza --color=always --icons --group-directories-first --all'
	alias ll='eza --color=always --icons --group-directories-first --all --long'
	alias tree='eza --color=always --icons --group-directories-first --tree'
	alias l='ll'
fi

# Editor
if command -v nvim &>/dev/null; then
	alias vim='nvim'
	alias vi='nvim'
	alias v='nvim'
	alias sv='sudoedit'
	alias vudo='sudoedit'
fi

# Tmux
alias t='tmux'
alias tc='tmux attach'
alias ta='tmux attach -t'
alias tl='tmux ls'
alias ts='tmux new-session -s'
alias tk='tmux kill-session -t'

# Git
alias gg='lazygit'
alias gs='git st'
alias gb='git checkout -b'
alias gc='git commit'
alias gcp='git commit -p'
alias gpp='git push'
alias gp='git pull'

# Grep / find
alias grep='rg'
alias fda='fd -IH'
alias rga='rg -uu'

# systemctl
alias s='systemctl'
alias su='systemctl --user'
alias ss='systemctl status'
alias sl='systemctl --type service --state running'
alias slu='systemctl --user --type service --state running'
alias sf='systemctl --failed --all'

# journalctl
alias jb='journalctl -b'
alias jf='journalctl -f'
alias jg='journalctl -b --grep'
alias ju='journalctl --unit'
alias jm='journalctl --user'

# paru
if command -v paru &>/dev/null; then
	alias p='paru'
	alias pai='paru -S'
	alias par='paru -R'
	alias pas='paru -Ss'
	alias pal='paru -Q'
	alias paf='paru -Ql'
	alias pao='paru -Qo'
fi

# ── Tool integrations ────────────────────────────────────────────────

# Starship prompt
command -v starship &>/dev/null && eval "$(starship init bash)"

# Atuin (shell history)
command -v atuin &>/dev/null && eval "$(atuin init bash)"

# Zoxide (smart cd)
command -v zoxide &>/dev/null && eval "$(zoxide init bash)"

# Direnv
command -v direnv &>/dev/null && eval "$(direnv hook bash)"
