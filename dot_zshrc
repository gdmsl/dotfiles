# Reset zsh state (useful on shared clusters)
emulate -R zsh

# Load local overrides
[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"

# Vi mode
bindkey -v
export KEYTIMEOUT=1

# History
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt hist_ignore_all_dups hist_reduce_blanks share_history append_history

# Shell options
setopt auto_cd interactive_comments glob_dots

# Completion (built-in, no plugin manager needed)
autoload -Uz compinit && compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'

# ── Aliases (mirroring fish) ─────────────────────────────────────────

# Files & directories
alias mv='mv -iv'
alias cp='cp -riv'
alias mkdir='mkdir -vp'
if (( $+commands[eza] )); then
	alias ls='eza --color=always --icons --group-directories-first'
	alias la='eza --color=always --icons --group-directories-first --all'
	alias ll='eza --color=always --icons --group-directories-first --all --long'
	alias tree='eza --color=always --icons --group-directories-first --tree'
	alias l='ll'
fi

# Editor
if (( $+commands[nvim] )); then
	alias vim='nvim'
	alias vi='nvim'
	alias v='nvim'
	alias sv='sudoedit'
	alias vudo='sudoedit'
fi

# Tmux
alias t='tmux'
alias tc='tmux attach'
alias ta='tmux attach -t'
alias tl='tmux ls'
alias ts='tmux new-session -s'
alias tk='tmux kill-session -t'

# Git
alias gg='lazygit'
alias gs='git st'
alias gb='git checkout -b'
alias gc='git commit'
alias gcp='git commit -p'
alias gpp='git push'
alias gp='git pull'

# Grep / find
alias grep='rg'
alias fda='fd -IH'
alias rga='rg -uu'

# systemctl
alias s='systemctl'
alias su='systemctl --user'
alias ss='systemctl status'
alias sl='systemctl --type service --state running'
alias slu='systemctl --user --type service --state running'
alias sf='systemctl --failed --all'

# journalctl
alias jb='journalctl -b'
alias jf='journalctl -f'
alias jg='journalctl -b --grep'
alias ju='journalctl --unit'
alias jm='journalctl --user'

# paru
if (( $+commands[paru] )); then
	alias p='paru'
	alias pai='paru -S'
	alias par='paru -R'
	alias pas='paru -Ss'
	alias pal='paru -Q'
	alias paf='paru -Ql'
	alias pao='paru -Qo'
fi

# ── Tool integrations ────────────────────────────────────────────────

# Starship prompt
(( $+commands[starship] )) && eval "$(starship init zsh)"

# Atuin (shell history)
(( $+commands[atuin] )) && eval "$(atuin init zsh)"

# Zoxide (smart cd)
(( $+commands[zoxide] )) && eval "$(zoxide init zsh)"

# Direnv
(( $+commands[direnv] )) && eval "$(direnv hook zsh)"
